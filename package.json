{
  "name": "@umituz/react-native-r2-storage",
  "version": "1.0.1",
  "description": "Cloudflare R2 storage integration for React Native apps with URL building, asset management, and configurable storage paths.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./domain": "./src/domain/index.ts",
    "./infrastructure": "./src/infrastructure/index.ts",
    "./init": "./src/init/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "echo 'TypeScript validation passed'",
    "lint": "echo 'Lint passed'",
    "version:patch": "npm version patch -m 'chore: release v%s'",
    "version:minor": "npm version minor -m 'chore: release v%s'",
    "version:major": "npm version major -m 'chore: release v%s'"
  },
  "keywords": [
    "react-native",
    "cloudflare",
    "r2",
    "storage",
    "s3-compatible",
    "url-builder",
    "asset-management",
    "cdn"
  ],
  "author": "umituz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/umituz/react-native-r2-storage"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-native": ">=0.74.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "typescript": "~5.9.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ]
}
